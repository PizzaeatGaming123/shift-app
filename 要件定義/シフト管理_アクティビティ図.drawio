        <mxCell id="div-2" style="endArrow=none;html=1;strokeColor=#666666;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="600" y="60" as="sourcePoint" /><mxPoint x="600" y="1300" as="targetPoint" /></mxGeometry></mxCell>
